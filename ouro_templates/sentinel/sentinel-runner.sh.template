#!/usr/bin/env bash
# Ouro Sentinel Runner — Daemon that manages the continuous review loop.
#
# Usage:
#   sentinel-runner.sh start    # Start the sentinel loop
#   sentinel-runner.sh stop     # Stop the sentinel loop
#   sentinel-runner.sh restart  # Restart the sentinel loop
#   sentinel-runner.sh status   # Check if running
#
# Generated by: ouro-sentinel install

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

MODEL="{{MODEL}}"
MAX_TURNS="{{MAX_TURNS}}"
TIMEOUT_MINUTES="{{TIMEOUT}}"
COOLDOWN_SECONDS="{{COOLDOWN}}"

# Derive paths from script location (portable — survives directory moves)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SENTINEL_DIR="${SCRIPT_DIR}"
SENTINEL_CLAUDE_MD="${SENTINEL_DIR}/CLAUDE.md"
PROJECT_PATH="$(cd "${SENTINEL_DIR}/../.." && pwd)"

# ---------------------------------------------------------------------------
# Derived paths
# ---------------------------------------------------------------------------

PID_FILE="${SENTINEL_DIR}/sentinel.pid"
LOG_FILE="${SENTINEL_DIR}/runner.log"
STATE_FILE="${SENTINEL_DIR}/state.json"
MAX_LOG_SIZE=$((10 * 1024 * 1024))  # 10MB

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log() {
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >> "${LOG_FILE}"
}

die() {
    echo "Error: $*" >&2
    exit 1
}

is_running() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(cat "${PID_FILE}" 2>/dev/null)
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

rotate_log() {
    if [ -f "${LOG_FILE}" ]; then
        local size
        size=$(stat -f%z "${LOG_FILE}" 2>/dev/null || stat -c%s "${LOG_FILE}" 2>/dev/null || echo 0)
        if [ "${size}" -gt "${MAX_LOG_SIZE}" ]; then
            gzip -c "${LOG_FILE}" > "${LOG_FILE}.$(date +%Y%m%d%H%M%S).gz"
            : > "${LOG_FILE}"
            log "Log rotated"
        fi
    fi
}

cleanup_worktrees() {
    # Remove any leftover sentinel worktrees
    local worktree_path="${SENTINEL_DIR}/worktree"
    if [ -d "${worktree_path}" ]; then
        git -C "${PROJECT_PATH}" worktree remove "${worktree_path}" --force 2>/dev/null || true
        rm -rf "${worktree_path}" 2>/dev/null || true
        log "Cleaned up stale worktree"
    fi
}

validate_state() {
    if [ ! -f "${STATE_FILE}" ]; then
        log "WARNING: state.json missing, sentinel may need re-init"
        return 1
    fi
    # Basic JSON validity check
    if ! STATE_FILE="${STATE_FILE}" python3 -c "import json,os; json.load(open(os.environ['STATE_FILE']))" 2>/dev/null; then
        log "WARNING: state.json corrupted, attempting backup restore"
        if [ -f "${STATE_FILE}.bak" ]; then
            cp "${STATE_FILE}.bak" "${STATE_FILE}"
            log "Restored state.json from backup"
        else
            log "ERROR: No backup available, sentinel needs re-init"
            return 1
        fi
    fi
    # Backup current state
    cp "${STATE_FILE}" "${STATE_FILE}.bak"
    return 0
}

# ---------------------------------------------------------------------------
# Signal handling
# ---------------------------------------------------------------------------

RUNNING=true

handle_signal() {
    log "Received signal, shutting down gracefully..."
    RUNNING=false
}

trap handle_signal SIGTERM SIGINT

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_start() {
    if is_running; then
        local pid
        pid=$(cat "${PID_FILE}")
        echo "Sentinel already running (PID: ${pid})"
        exit 0
    fi

    echo "Starting Ouro Sentinel..."
    log "=== Sentinel starting ==="
    log "Model: ${MODEL} | Max turns: ${MAX_TURNS} | Timeout: ${TIMEOUT_MINUTES}m"

    # Validate prerequisites
    [ -d "${SENTINEL_DIR}" ] || die "Sentinel not initialized: ${SENTINEL_DIR}"
    [ -f "${SENTINEL_CLAUDE_MD}" ] || die "Sentinel CLAUDE.md not found: ${SENTINEL_CLAUDE_MD}"
    command -v claude >/dev/null 2>&1 || die "Claude CLI not found in PATH"

    # Clean up any previous state
    cleanup_worktrees

    # Write PID
    echo $$ > "${PID_FILE}"

    # Main loop
    local session_count=0

    while ${RUNNING}; do
        session_count=$((session_count + 1))
        log "--- Session ${session_count} starting ---"

        # Validate state before each session
        if ! validate_state; then
            log "State validation failed, exiting"
            break
        fi

        # Rotate log if needed
        rotate_log

        # Launch Claude session
        # --permission-mode bypassPermissions is required for unattended operation
        # --add-dir ensures sentinel state files are writable
        # SECURITY: only use in trusted, sandboxed environments
        local session_output="${SENTINEL_DIR}/session-output.tmp"
        local exit_code=0
        timeout "$((TIMEOUT_MINUTES * 60))" claude \
            --model "${MODEL}" \
            --max-turns "${MAX_TURNS}" \
            --system-prompt "$(cat "${SENTINEL_CLAUDE_MD}")" \
            --permission-mode bypassPermissions \
            --add-dir "${SENTINEL_DIR}" \
            --print \
            --verbose \
            -p "Read state files and execute the next review iteration. Follow the Review Loop in your instructions exactly." \
            > "${session_output}" 2>>"${LOG_FILE}" || exit_code=$?

        log "Session ${session_count} exited with code ${exit_code}"

        # Check for exit signals in stdout (agent outputs ROTATE/DONE/BLOCKED)
        if grep -q "BLOCKED" "${session_output}" 2>/dev/null; then
            log "BLOCKED signal detected, pausing sentinel"
            echo "Sentinel BLOCKED — human intervention required"
            cat "${session_output}" >> "${LOG_FILE}"
            rm -f "${session_output}"
            break
        fi

        if grep -q "DONE" "${session_output}" 2>/dev/null; then
            log "DONE signal — all partitions reviewed, entering extended cooldown"
            echo "Sentinel completed full review cycle"
            cat "${session_output}" >> "${LOG_FILE}"
            rm -f "${session_output}"
            break
        fi

        # ROTATE or normal exit — archive output and continue
        cat "${session_output}" >> "${LOG_FILE}" 2>/dev/null
        rm -f "${session_output}"

        # Clean up any worktrees from this session
        cleanup_worktrees

        if ${RUNNING}; then
            log "Cooldown: ${COOLDOWN_SECONDS}s"
            # Background sleep so SIGTERM/SIGINT interrupts immediately
            sleep "${COOLDOWN_SECONDS}" &
            wait $! || true
        fi
    done

    # Cleanup
    rm -f "${PID_FILE}"
    log "=== Sentinel stopped ==="
    echo "Sentinel stopped."
}

cmd_stop() {
    if ! is_running; then
        echo "Sentinel is not running"
        rm -f "${PID_FILE}"
        exit 0
    fi

    local pid
    pid=$(cat "${PID_FILE}")
    echo "Stopping Sentinel (PID: ${pid})..."
    kill "${pid}" 2>/dev/null || true

    # Wait for graceful shutdown (up to 30s)
    local wait=0
    while kill -0 "${pid}" 2>/dev/null && [ ${wait} -lt 30 ]; do
        sleep 1
        wait=$((wait + 1))
    done

    if kill -0 "${pid}" 2>/dev/null; then
        echo "Force killing..."
        kill -9 "${pid}" 2>/dev/null || true
    fi

    rm -f "${PID_FILE}"
    cleanup_worktrees
    echo "Sentinel stopped."
}

cmd_restart() {
    cmd_stop
    sleep 2
    cmd_start
}

cmd_status() {
    if is_running; then
        local pid
        pid=$(cat "${PID_FILE}")
        echo "Sentinel is running (PID: ${pid})"
    else
        echo "Sentinel is not running"
    fi

    # Show quick state summary
    if [ -f "${STATE_FILE}" ]; then
        STATE_FILE="${STATE_FILE}" python3 -c "
import json, os
with open(os.environ['STATE_FILE']) as fh:
    s = json.load(fh)
print(f\"  Iteration: {s.get('current_iteration', 0)}\")
print(f\"  Findings:  {s.get('total_findings', 0)}\")
print(f\"  Coverage:  {s.get('coverage_percent', 0):.1f}%\")
print(f\"  Status:    {s.get('status', 'unknown')}\")
" 2>/dev/null || true
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

case "${1:-}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    status)  cmd_status ;;
    *)
        echo "Usage: $(basename "$0") {start|stop|restart|status}"
        exit 1
        ;;
esac
